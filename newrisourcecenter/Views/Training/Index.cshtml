@{
    ViewBag.Title = "Training";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .rc-loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.6);
        z-index: 1030;
        display: none;
    }

    .rc-loading-box {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 12px 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.12);
        display: flex;
        align-items: center;
        gap: 10px;
        color: #333;
    }

    .rc-spinner {
        width: 18px;
        height: 18px;
        border: 2px solid #ddd;
        border-top-color: #337ab7;
        border-radius: 50%;
        animation: rcspin 0.9s linear infinite;
    }

    @@keyframes rcspin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @@media (max-width: 767px) {
        .training-actions .btn {
            display: block;
            width: 100%;
            margin-bottom: 8px;
        }

        .training-actions .btn:last-child {
            margin-bottom: 0;
        }
    }

    .training-card {
        margin-bottom: 15px;
    }

    .panel-group .training-card {
        margin-bottom: 15px;
    }

    .training-card .panel-heading {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .training-actions {
        margin-top: 8px;
    }

    .training-actions .btn {
        margin-right: 6px;
        margin-bottom: 6px;
    }

    @@media (max-width: 767px) {
        .training-actions .btn {
            margin-right: 0;
        }
    }

    .training-hint {
        margin-top: 10px;
        padding: 8px 10px;
        background: #f7f7f7;
        border: 1px solid #e5e5e5;
        border-radius: 4px;
    }

    .training-meta {
        margin-top: 6px;
        margin-bottom: 10px;
    }

    .training-meta-row {
        margin-top: 4px;
        line-height: 1.4;
    }

    .training-meta {
        font-size: 12px;
    }

    .training-meta-item {
        display: inline-block;
        margin-right: 12px;
        margin-bottom: 2px;
        white-space: nowrap;
    }

    .training-meta-item:last-child {
        margin-right: 0;
    }

    .training-meta-row:first-child {
        margin-top: 0;
    }

    .training-meta .label {
        margin-right: 6px;
    }

    #videoModal {
        z-index: 1060;
    }

    #videoModal .modal-body {
        max-height: calc(100vh - 180px);
        overflow: auto;
    }

    #videoModal .modal-content {
        overflow-x: hidden;
    }

    @@media (min-width: 768px) {
        #videoModal .modal-dialog {
            width: 95vw;
            max-width: 1200px;
        }
    }

    #videoModal .embed-responsive {
        max-width: 100%;
    }

    #videoModal #trainingVideo {
        width: 100%;
        max-width: 100%;
        height: 100%;
        max-height: calc(100vh - 240px);
        object-fit: contain;
        background: #000;
        display: block;
    }

    .modal-backdrop {
        z-index: 2990;
    }

    #quizModal,
    #videoModal {
        z-index: 3000;
    }
</style>

<div id="rcLoading" class="rc-loading-overlay" aria-hidden="true">
    <div class="rc-loading-box">
        <div class="rc-spinner"></div>
        <div>Loading…</div>
    </div>
</div>

<div class="main_content" style="padding-top:20px; padding-bottom:20px;">
    <div class="container">
        <div class="row">
            <div class="col-xs-12">
                <div class="clearfix">
                    <h2 class="pull-left" style="margin-top:0;">My Trainings</h2>
                </div>
                <div id="trackSummary" style="margin-top:15px;"></div>
                <div id="trainingList" style="margin-top:15px;"></div>

                <div class="modal fade" id="quizModal" tabindex="-1" role="dialog" aria-hidden="true">
                    <div class="modal-dialog modal-lg" role="document">
                        <div class="modal-content">
                            <div class="modal-header">
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                <h4 class="modal-title">Quiz</h4>
                                <div class="text-muted" style="margin-top:4px;">Select all that apply</div>
                            </div>
                            <div class="modal-body">
                                <form id="quizForm">
                                    <div id="quizQuestions"></div>
                                    <button type="submit" class="btn btn-success btn-block">Submit Quiz</button>
                                </form>
                                <div id="resultContainer" style="display:none; margin-top:15px;" class="alert alert-info"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="videoModal" tabindex="-1" role="dialog" aria-hidden="true">
                    <div class="modal-dialog modal-lg" role="document">
                        <div class="modal-content">
                            <div class="modal-header">
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                <h4 class="modal-title" id="videoModalTitle">Video</h4>
                            </div>
                            <div class="modal-body">
                                <div class="embed-responsive embed-responsive-16by9">
                                    <video id="trainingVideo" class="embed-responsive-item" controls playsinline></video>
                                </div>
                                <div id="videoModalMessage" class="alert alert-info" style="display:none; margin-top:10px;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var $rcLoading = $('#rcLoading');
        if ($rcLoading.length) {
            $(document)
                .off('.rcLoading')
                .on('ajaxStart.rcLoading', function () { $rcLoading.show(); })
                .on('ajaxStop.rcLoading', function () { $rcLoading.hide(); })
                .on('ajaxError.rcLoading', function () { $rcLoading.hide(); });
        }

        var activeTrainingId = 0;
        var trainings = [];
        var startedTrainingIds = {};
        var startedAtByTrainingId = {};
        var quizSubmittedByTrainingId = {};
        var availableTrainingClasses = [];
        var selectedTrainingClass = '';

        if ($('#videoModal').length) {
            $('#videoModal').appendTo('body');
        }

        // ... rest of the code remains the same ...
        function loadAssignedTrainings(done) {
            $.getJSON('/Training/GetAssignedTrainings', function (data) {
                trainings = data || [];
                startedTrainingIds = {};
                startedAtByTrainingId = {};
                quizSubmittedByTrainingId = {};
                availableTrainingClasses = [];
                for (var i = 0; i < trainings.length; i++) {
                    if (trainings[i].IsStarted) {
                        startedTrainingIds[trainings[i].Id] = true;
                        if (trainings[i].StartedAtUtc) {
                            startedAtByTrainingId[trainings[i].Id] = trainings[i].StartedAtUtc;
                        }
                    }

                    var st = (trainings[i].Status || '').toString();
                    if (st === 'Completed' || st === 'Failed') {
                        quizSubmittedByTrainingId[trainings[i].Id] = true;
                    }

                    var cls = (trainings[i].TrainingClass || '').toString().trim();
                    if (cls) {
                        availableTrainingClasses.push(cls);
                    }
                }

                availableTrainingClasses = dedupeStrings(availableTrainingClasses);
                availableTrainingClasses.sort(function (a, b) { return a.localeCompare(b); });
                loadTrackSummary();
                renderTrainingCards();
                if (typeof done === 'function') {
                    done();
                }
            });
        }

        var trackSummaryItems = [];
        function loadTrackSummary(done) {
            $.getJSON('/Training/GetTrainingTrackSummary', function (data) {
                trackSummaryItems = data || [];
                if (!selectedTrainingClass) {
                    if (trackSummaryItems.length && trackSummaryItems[0].TrainingClass) {
                        selectedTrainingClass = trackSummaryItems[0].TrainingClass;
                    } else if (availableTrainingClasses.length) {
                        selectedTrainingClass = availableTrainingClasses[0];
                    }
                }
                renderTrackSummary();
                if (typeof done === 'function') {
                    done();
                }
            }).fail(function () {
                trackSummaryItems = [];
                renderTrackSummary();
                if (typeof done === 'function') {
                    done();
                }
            });
        }

        function renderTrackSummary() {
            var $wrap = $('#trackSummary');
            if (!$wrap.length) return;

            var selectedClass = (selectedTrainingClass || '').toString();
            if (!selectedClass) {
                $wrap.html('');
                return;
            }

            var items = trackSummaryItems || [];
            if (!items.length) {
                $wrap.html('');
                return;
            }

            var selectedItem = null;
            for (var i = 0; i < items.length; i++) {
                if ((items[i].TrainingClass || '').toString().toLowerCase() === selectedClass.toLowerCase()) {
                    selectedItem = items[i];
                    break;
                }
            }
            if (!selectedItem) {
                $wrap.html('');
                return;
            }

            var html = '';
            html += '<div class="panel panel-default" style="margin-bottom:0;">';
            html += '<div class="panel-heading"><strong>Training Track</strong></div>';
            html += '<div class="panel-body">';

            html += '<div style="margin-bottom:10px;">';
            for (var j = 0; j < items.length; j++) {
                var cls = (items[j].TrainingClass || '').toString();
                if (!cls) continue;
                var isActive = cls.toLowerCase() === selectedClass.toLowerCase();
                html += '<button type="button" class="btn btn-sm ' + (isActive ? 'btn-primary' : 'btn-default') + '" style="margin-right:8px; margin-bottom:6px;" onclick="selectTrackClass(\'' + jsString(cls) + '\')">'
                    + htmlEncode(toTitleCase(cls)) + '</button>';
            }
            html += '</div>';

            if (selectedItem.CompleteDays && selectedItem.CompleteDays > 0) {
                html += '<div class="text-muted" style="margin-bottom:6px;"><strong>Days to Complete:</strong> ' + selectedItem.CompleteDays + '</div>';
            }

            html += '<div class="text-muted" style="margin-bottom:10px;"><strong>Progress:</strong> '
                + (selectedItem.CompletedCourses || 0) + ' / ' + (selectedItem.TotalCourses || 0)
                + (selectedItem.IsComplete ? ' <span class="label label-success">Completed</span>' : '')
                + '</div>';

            if (selectedItem.Prize) {
                html += '<div style="margin-bottom:10px;">';
                html += '<div class="text-muted" style="margin-bottom:6px;"><strong>Reward:</strong></div>';
                html += '<div class="row">';
                html += '<div class="col-xs-12 col-sm-4">';
                if (selectedItem.ImageUrl) {
                    var imgSrc = '/img/training/' + selectedItem.ImageUrl;
                    html += '<a href="' + htmlEncode(imgSrc) + '" target="_blank">'
                        + '<img src="' + htmlEncode(imgSrc) + '" style="max-width:100%; height:auto; border:1px solid #eee;" />'
                        + '</a>';
                }
                html += '</div>';
                html += '<div class="col-xs-12 col-sm-8">';
                html += '<div style="font-weight:bold;">' + htmlEncode(selectedItem.Prize).replace(/,/g, '<br/>') + '</div>';
                html += '</div>';
                html += '</div>';
                html += '</div>';
            }

            html += '</div></div>';
            $wrap.html(html);
        }

        window.selectTrackClass = function (cls) {
            selectedTrainingClass = (cls || '').toString();
            renderTrackSummary();
            renderTrainingCards();
        };

        function jsString(value) {
            value = (value || '').toString();
            return value.replace(/\\/g, '\\\\').replace(/'/g, "\\'");
        }

        function dedupeStrings(items) {
            var map = {};
            var result = [];
            for (var i = 0; i < items.length; i++) {
                var key = (items[i] || '').toString();
                if (!key) continue;
                var lower = key.toLowerCase();
                if (map[lower]) continue;
                map[lower] = true;
                result.push(key);
            }
            return result;
        }

        function toTitleCase(text) {
            text = (text || '').toString().trim();
            if (!text) return '';
            return text.replace(/\w\S*/g, function (w) {
                return w.charAt(0).toUpperCase() + w.substr(1).toLowerCase();
            });
        }

        function parseDate(value) {
            if (!value) return null;
            if (typeof value === 'string') {
                var match = /\/Date\((\d+)\)\//.exec(value);
                if (match && match[1]) {
                    var ticks = parseInt(match[1], 10);
                    if (!isNaN(ticks)) {
                        return new Date(ticks);
                    }
                }
            }
            var d = new Date(value);
            if (!isNaN(d.getTime())) return d;
            return null;
        }

        function pad(n) {
            return (n < 10 ? '0' : '') + n;
        }

        function formatElapsed(seconds) {
            seconds = Math.max(0, Math.floor(seconds));
            var h = Math.floor(seconds / 3600);
            var m = Math.floor((seconds % 3600) / 60);
            var s = seconds % 60;
            return pad(h) + ':' + pad(m) + ':' + pad(s);
        }

        function formatHoursFromSeconds(seconds) {
            var sec = parseInt(seconds, 10);
            if (!isFinite(sec) || sec <= 0) return '0';
            var hours = sec / 3600;
            return (Math.round(hours * 100) / 100).toString();
        }

        function updateTimers() {
            $('[data-training-timer="1"]').each(function () {
                var $el = $(this);
                var started = $el.attr('data-started');
                var d = parseDate(started);
                if (!d) {
                    $el.text('');
                    return;
                }
                var elapsedSeconds = (new Date().getTime() - d.getTime()) / 1000;
                $el.text(formatElapsed(elapsedSeconds));
            });
        }

        function renderTrainingCards() {
            var html = '';
            if (!trainings.length) {
                html = '<p>No training assigned for your role.</p>';
                $('#trainingList').html(html);
                return;
            }

            var selectedClass = (selectedTrainingClass || '').toString().toLowerCase();
            if (!selectedClass && availableTrainingClasses.length) {
                selectedTrainingClass = availableTrainingClasses[0];
                selectedClass = selectedTrainingClass.toLowerCase();
                renderTrackSummary();
            }

            html += '<div class="panel-group" id="trainingAccordion" role="tablist" aria-multiselectable="true">';
            for (var i = 0; i < trainings.length; i++) {
                var t = trainings[i];
                var tClass = (t.TrainingClass || '').toString().trim().toLowerCase();
                if (!selectedClass || !tClass || tClass !== selectedClass) {
                    continue;
                }
                var isStarted = !!startedTrainingIds[t.Id];
                var status = t.Status || (isStarted ? 'InProgress' : 'NotStarted');
                var statusDisplay = t.StatusDisplay || (status === 'InProgress' ? 'In Progress' : (status === 'NotStarted' ? 'Not Started' : status));
                var primaryText = 'Start Training';
                if (status === 'InProgress') {
                    primaryText = 'Restart Training';
                } else if (status === 'Failed' || status === 'Completed') {
                    primaryText = 'Retake Training';
                }

                var statusLabelClass = 'label-default';
                if (status === 'InProgress') statusLabelClass = 'label-warning';
                if (status === 'Failed') statusLabelClass = 'label-danger';
                if (status === 'Completed') statusLabelClass = 'label-success';

                var panelId = 'trainingPanel_' + t.Id;
                var headingId = 'trainingHeading_' + t.Id;
                var collapseId = 'trainingCollapse_' + t.Id;

                html += '<div class="panel panel-default training-card" id="' + panelId + '">';
                html += '<div class="panel-heading" role="tab" id="' + headingId + '">';
                html += '<h4 class="panel-title" style="margin:0;">';
                html += '<a role="button" data-toggle="collapse" data-parent="#trainingAccordion" href="#' + collapseId + '" aria-expanded="false" aria-controls="' + collapseId + '" style="display:block; text-decoration:none;">';
                html += '<strong>' + htmlEncode(t.Title || '') + '</strong>';
                html += '</a>';
                html += '</h4>';
                html += '<div class="training-meta">';
                html += '<div class="training-meta-row">';
                html += '<span class="label ' + statusLabelClass + '">' + htmlEncode(statusDisplay) + '</span>';

                var className = (t.TrainingClass || '').toString().trim();
                if (className) {
                    html += '<span class="training-meta-item text-muted">Track: ' + htmlEncode(toTitleCase(className)) + '</span>';
                }

                html += '</div>';
                html += '<div class="training-meta-row">';

                var assignedAt = t.AssignedAtIso || t.AssignedAtUtc || '';
                var assignedDate = parseDate(assignedAt);
                if (assignedDate) {
                    html += '<span class="training-meta-item text-muted">Assigned: ' + htmlEncode(assignedDate.toLocaleDateString()) + '</span>';
                }

                if (status === 'InProgress') {
                    var startedAt = t.StartedAtIso || t.StartedAtUtc || startedAtByTrainingId[t.Id] || '';
                    var startedDate = parseDate(startedAt);

                    html += '<span class="training-meta-item text-muted">Started: ' + htmlEncode(startedDate ? startedDate.toLocaleString() : '') + '</span>';
                    html += '<span class="training-meta-item text-muted">Elapsed: <span class="text-muted" data-training-timer="1" data-started="' + htmlEncode(startedAt) + '"></span></span>';
                } else if (status === 'Completed' || status === 'Failed') {
                    if (t.LastScorePercentage != null) {
                        html += '<span class="training-meta-item text-muted">Score: ' + t.LastScorePercentage + '%</span>';
                    }
                }

                html += '</div>';
                html += '</div>';
                html += '</div>';

                html += '<div id="' + collapseId + '" class="panel-collapse collapse" role="tabpanel" aria-labelledby="' + headingId + '">';
                html += '<div class="panel-body">';
                html += '<p class="text-muted" style="margin-bottom:10px;">' + htmlEncode(t.Description || '') + '</p>';
                html += '<p style="margin-bottom:12px;">Pass Percentage: <strong>' + (t.PassingPercentage || 0) + '%</strong></p>';

                html += '<div class="training-actions">';
                html += '<button class="btn btn-primary btn-sm" onclick="startTraining(' + t.Id + ')">' + htmlEncode(primaryText) + '</button>';

                if (t.PdfPath) {
                    if (isStarted) {
                        html += '<button class="btn btn-default btn-sm" onclick="openContent(' + t.Id + ',\'pdf\')">Open PDF</button>';
                    } else {
                        html += '<button class="btn btn-default btn-sm" disabled>Open PDF</button>';
                    }
                }

                if (t.VideoPath) {
                    if (isStarted) {
                        html += '<button class="btn btn-default btn-sm" onclick="openVideo(' + t.Id + ')">Watch Video</button>';
                    } else {
                        html += '<button class="btn btn-default btn-sm" disabled>Watch Video</button>';
                    }
                }

                var quizLocked = !!quizSubmittedByTrainingId[t.Id];
                var canTakeQuiz = (t.CanTakeQuiz === true);
                if (isStarted && !quizLocked && canTakeQuiz) {
                    html += '<button class="btn btn-info btn-sm" onclick="loadQuiz(' + t.Id + ')">Take Quiz</button>';
                } else {
                    html += '<button class="btn btn-info btn-sm" disabled>Take Quiz</button>';
                }
                html += '</div>';

                if (!isStarted) {
                    html += '<div class="training-hint text-muted">'
                        + '<strong>How to complete:</strong><br/>'
                        + '1) Click <strong>Start Training</strong><br/>'
                        + '2) Review the PDF/Video content<br/>'
                        + '3) Take the quiz to finish'
                        + '</div>';
                }
                html += '</div></div>';
                html += '</div>';
            }
            html += '</div>';
            $('#trainingList').html(html);

            updateTimers();
        }

        $('#videoModal').on('hidden.bs.modal', function () {
            var video = document.getElementById('trainingVideo');
            if (video) {
                try { video.pause(); } catch (e) { }
                $('#trainingVideo').removeAttr('src');
                try { video.load(); } catch (e) { }
            }
        });

        $('#quizModal').on('hidden.bs.modal', function () {
            $('#quizQuestions').html('');
            $('#resultContainer').hide().text('');

            var id = activeTrainingId;
            if (id && quizSubmittedByTrainingId[id]) {
                loadAssignedTrainings(function () {
                    var $collapse = $('#trainingCollapse_' + id);
                    if ($collapse.length) {
                        $collapse.collapse('show');
                    }
                });
            }
        });

        function refreshTrainingPanel(id) {
            if (!id) return;
            loadAssignedTrainings(function () {
                var $collapse = $('#trainingCollapse_' + id);
                if ($collapse.length) {
                    $collapse.collapse('show');
                }
            });
        }

        window.startTraining = function (id) {
            $.post('/Training/StartTraining', { trainingContentId: id }, function () {
                activeTrainingId = id;
                startedTrainingIds[id] = true;
                quizSubmittedByTrainingId[id] = false;
                loadAssignedTrainings(function () {
                    var $collapse = $('#trainingCollapse_' + id);
                    if ($collapse.length) {
                        $collapse.collapse('show');
                    }
                });
            });
        };

        window.openContent = function (id, type) {
            if (!startedTrainingIds[id]) {
                alert('Please click Start first.');
                return;
            }

            var url = '/Training/OpenContent?trainingContentId=' + id + '&contentType=' + encodeURIComponent(type);
            window.open(url, '_blank');

            setTimeout(function () {
                refreshTrainingPanel(id);
            }, 800);
        };

        window.openVideo = function (id) {
            if (!startedTrainingIds[id]) {
                alert('Please click Start first.');
                return;
            }

            activeTrainingId = id;
            var url = '/Training/OpenContent?trainingContentId=' + id + '&contentType=' + encodeURIComponent('video');
            $('#videoModalMessage').hide();
            $('#trainingVideo').attr('src', url);
            $('#videoModal').modal('show');

            setTimeout(function () {
                refreshTrainingPanel(id);
            }, 800);
        };

        window.loadQuiz = function (id) {
            activeTrainingId = id;
            if (quizSubmittedByTrainingId[id]) {
                alert('Quiz already submitted. Please retake the training to take the quiz again.');
                return;
            }
            var t = null;
            for (var i = 0; i < trainings.length; i++) {
                if (trainings[i].Id === id) { t = trainings[i]; break; }
            }
            if (t && t.CanTakeQuiz !== true) {
                alert('Please open all required training content before taking the quiz.');
                return;
            }
            $.getJSON('/Training/GetQuiz', { trainingContentId: id }, function (quiz) {
                if (!quiz || !quiz.length) {
                    alert('No quiz configured for this training.');
                    return;
                }

                var qHtml = '';
                for (var i = 0; i < quiz.length; i++) {
                    var q = quiz[i];
                    qHtml += '<div class="panel panel-default" style="margin-bottom:12px;">';
                    qHtml += '<div class="panel-body">';
                    qHtml += '<p style="margin-top:0;"><strong>' + htmlEncode(q.QuestionText || '') + '</strong></p>';
                    for (var j = 0; j < q.Options.length; j++) {
                        var o = q.Options[j];
                        qHtml += '<label class="checkbox" style="margin-top:6px; margin-bottom:6px;">';
                        qHtml += '<input type="checkbox" name="q_' + q.Id + '" value="' + o.Id + '" /> ' + htmlEncode(o.OptionText || '');
                        qHtml += '</label>';
                    }
                    qHtml += '</div></div>';
                }

                $('#quizQuestions').html(qHtml);
                $('#resultContainer').hide();
                $('#quizQuestions input, #quizForm button[type=submit]').prop('disabled', false);
                $('#quizForm button[type=submit]').text('Submit Quiz');
                $rcLoading.hide();
                $('#quizModal').modal('show');
            }).fail(function (xhr) {
                $rcLoading.hide();
                alert(xhr.responseText || 'Quiz is not available yet.');
            });
        };

        $('#quizForm').on('submit', function (e) {
            e.preventDefault();
            var answersMap = {};
            $('#quizQuestions input[type=checkbox]:checked').each(function () {
                var name = $(this).attr('name');
                var questionId = parseInt(name.replace('q_', ''), 10);
                var selectedOptionId = parseInt($(this).val(), 10);
                if (!answersMap[questionId]) {
                    answersMap[questionId] = [];
                }
                answersMap[questionId].push(selectedOptionId);
            });

            var answers = [];
            for (var qId in answersMap) {
                if (!answersMap.hasOwnProperty(qId)) {
                    continue;
                }
                answers.push({ QuestionId: parseInt(qId, 10), SelectedOptionIds: answersMap[qId] });
            }

            var payload = { ContentId: activeTrainingId, Answers: answers };
            $.ajax({
                url: '/Training/SubmitQuiz',
                method: 'POST',
                contentType: 'application/json; charset=utf-8',
                data: JSON.stringify(payload),
                success: function (result) {
                    var msg = 'Score: ' + result.scorePercentage + '% | Pass: ' + result.passPercentage + '% | ';
                    msg += result.isPassed ? 'Status: PASSED' : 'Status: FAILED';
                    msg += ' | Time: ' + formatHoursFromSeconds(result.elapsedSeconds) + ' hours';
                    $('#resultContainer').text(msg).show();

                    quizSubmittedByTrainingId[activeTrainingId] = true;
                    $('#quizQuestions input, #quizForm button[type=submit]').prop('disabled', true);
                    $('#quizForm button[type=submit]').text('Submitted');

                    refreshTrainingPanel(activeTrainingId);
                },
                error: function (xhr) {
                    alert(xhr.responseText || 'Unable to submit quiz.');
                }
            });
        });

        function htmlEncode(value) {
            return $('<div/>').text(value).html();
        }

        loadAssignedTrainings();

        setInterval(updateTimers, 1000);
    })();
</script>
