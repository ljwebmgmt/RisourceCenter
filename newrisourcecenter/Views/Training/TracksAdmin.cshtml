@{
    ViewBag.Title = "Training Admin - Tracks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="main_content" style="padding-top:20px; padding-bottom:20px;">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xs-12">
                <div class="clearfix">
                    <h2 class="pull-left" style="margin-top:0;">Manage Training Tracks</h2>
                    <div class="pull-right admin-header-actions" style="margin-top:3px;">
                        <button type="button" class="btn btn-primary btn-sm" id="btnAddTrack">Add Track</button>
                        <a href="/Training/AdminList" class="btn btn-default btn-sm" style="margin-left:8px;">Back to Trainings</a>
                    </div>
                </div>

                <div class="panel panel-default" style="margin-top:15px;">
                    <div class="panel-heading"><strong>Tracks</strong></div>
                    <div class="panel-body">
                        <div id="tracksError" class="alert alert-danger" style="display:none;"></div>
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered" id="tracksTable" style="margin-bottom:0;">
                                <thead>
                                    <tr>
                                        <th style="width:90px;">Picture</th>
                                        <th>Track</th>
                                        <th style="width:160px;">Completion Days</th>
                                        <th>Prize</th>
                                        <th style="width:90px;">Sort Order</th>
                                        <th style="width:120px;"></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

            <div class="modal fade" id="trackModal" tabindex="-1" role="dialog" aria-hidden="true">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                            <h4 class="modal-title" id="trackModalTitle">Track</h4>
                        </div>
                        <div class="modal-body">
                            <div class="alert alert-danger" id="trackModalError" style="display:none;"></div>

                            <input type="hidden" id="trackId" />

                            <form class="form-horizontal" onsubmit="return false;">
                                <div class="form-group">
                                    <label for="trackName" class="col-sm-3 control-label">Track</label>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="trackName" />
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="trackSortOrder" class="col-sm-3 control-label">Sort Order</label>
                                    <div class="col-sm-9">
                                        <input type="number" class="form-control" id="trackSortOrder" />
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="trackCompleteDays" class="col-sm-3 control-label">Days to Complete</label>
                                    <div class="col-sm-9">
                                        <input type="number" class="form-control" id="trackCompleteDays" />
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="trackPrize" class="col-sm-3 control-label">Prize</label>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="trackPrize" />
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="trackImageFile" class="col-sm-3 control-label">Picture</label>
                                    <div class="col-sm-9">
                                        <div id="trackImagePreview" style="margin-bottom:8px; display:none;"></div>
                                        <input type="file" class="form-control" id="trackImageFile" accept="image/*" />
                                        <div class="checkbox" style="margin-top:8px;">
                                            <label>
                                                <input type="checkbox" id="trackRemoveImage" /> Remove Image
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                            <button type="button" class="btn btn-primary" id="btnSaveTrack">Save</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section scripts {
<script>
    function htmlEncode(str) {
        return $('<div/>').text(str == null ? '' : str).html();
    }

    function toTitleCase(str) {
        str = (str || '').toString();
        return str.replace(/\w\S*/g, function (txt) {
            return txt.charAt(0).toUpperCase() + txt.substr(1).toLowerCase();
        });
    }

    function showPageError(msg) {
        var $e = $('#tracksError');
        if (!msg) {
            $e.hide().text('');
            return;
        }
        $e.text(msg).show();
    }

    function showModalError(msg) {
        var $e = $('#trackModalError');
        if (!msg) {
            $e.hide().text('');
            return;
        }
        $e.text(msg).show();
    }

    var tracks = [];

    function loadTracks() {
        showPageError('');
        $.getJSON('/Training/GetTrainingTracksManage', function (data) {
            tracks = data || [];
            renderTracks();
        }).fail(function (xhr) {
            showPageError((xhr && xhr.responseText) ? xhr.responseText : 'Failed to load tracks.');
        });
    }

    function renderTracks() {
        var $tbody = $('#tracksTable tbody');
        var rows = '';
        for (var i = 0; i < tracks.length; i++) {
            var t = tracks[i];
            var img = (t.ImageUrl || '').toString();
            var imgSrc = img ? ('/img/training/' + img) : '';
            rows += '<tr>';
            rows += '<td>' + (img ? ('<img src="' + htmlEncode(imgSrc) + '" style="height:32px; width:auto;" />') : '') + '</td>';
            rows += '<td>' + htmlEncode(toTitleCase(t.Name)) + '</td>';
            rows += '<td>' + htmlEncode(t.CompleteDays) + '</td>';
            rows += '<td>' + htmlEncode(t.Prize || '') + '</td>';
            rows += '<td>' + htmlEncode(t.SortOrder) + '</td>';
            rows += '<td class="text-center" style="white-space:nowrap;">'
                + '<div class="btn-group" role="group">'
                    + '<a class="btn btn-default btn-xs btn-edit" title="Edit" href="#" data-id="' + t.Id + '">'
                        + '<span class="glyphicon glyphicon-pencil" aria-hidden="true"></span>'
                    + '</a>'
                    + '<button type="button" class="btn btn-danger btn-xs btn-delete" title="Delete" data-id="' + t.Id + '">'
                        + '<span class="glyphicon glyphicon-trash" aria-hidden="true"></span>'
                    + '</button>'
                + '</div>'
                + '</td>';
            rows += '</tr>';
        }
        $tbody.html(rows);
    }

    function openModal(track) {
        showModalError('');
        if (track) {
            $('#trackModalTitle').text('Edit Track');
            $('#trackId').val(track.Id);
            $('#trackName').val(track.Name);
            $('#trackSortOrder').val(track.SortOrder);
            $('#trackCompleteDays').val(track.CompleteDays);
            $('#trackPrize').val(track.Prize || '');
            $('#trackRemoveImage').prop('checked', false);
            $('#trackImageFile').val('');

            var existing = (track.ImageUrl || '').toString();
            if (existing) {
                var src = '/img/training/' + existing;
                $('#trackImagePreview')
                    .html('<a href="' + htmlEncode(src) + '" target="_blank"><img src="' + htmlEncode(src) + '" style="max-height:80px; width:auto; border:1px solid #eee;" /></a>')
                    .show();
            } else {
                $('#trackImagePreview').html('').hide();
            }
        } else {
            $('#trackModalTitle').text('Add Track');
            $('#trackId').val('');
            $('#trackName').val('');
            $('#trackSortOrder').val('0');
            $('#trackCompleteDays').val('0');
            $('#trackPrize').val('');
            $('#trackRemoveImage').prop('checked', false);
            $('#trackImageFile').val('');
            $('#trackImagePreview').html('').hide();
        }
        $('#trackModal').modal('show');
    }

    function saveTrack() {
        showModalError('');
        var fd = new FormData();
        if ($('#trackId').val()) {
            fd.append('Id', $('#trackId').val());
        }
        fd.append('Name', $('#trackName').val());
        fd.append('SortOrder', $('#trackSortOrder').val() || '0');
        fd.append('CompleteDays', $('#trackCompleteDays').val() || '0');
        fd.append('Prize', $('#trackPrize').val());
        fd.append('RemoveImage', $('#trackRemoveImage').is(':checked'));

        var fileInput = document.getElementById('trackImageFile');
        if (fileInput && fileInput.files && fileInput.files.length) {
            fd.append('ImageFile', fileInput.files[0]);
        }

        $.ajax({
            url: '/Training/SaveTrainingTrack',
            method: 'POST',
            data: fd,
            processData: false,
            contentType: false
        }).done(function () {
            $('#trackModal').modal('hide');
            loadTracks();
        }).fail(function (xhr) {
            showModalError((xhr && xhr.responseText) ? xhr.responseText : 'Failed to save track.');
        });
    }

    function deleteTrack(id) {
        if (!confirm('Delete this track?')) return;

        showPageError('');
        $.ajax({
            url: '/Training/DeleteTrainingTrack',
            method: 'POST',
            data: { id: id }
        }).done(function () {
            loadTracks();
        }).fail(function (xhr) {
            showPageError((xhr && xhr.responseText) ? xhr.responseText : 'Failed to delete track.');
        });
    }

    $(function () {
        loadTracks();

        $('#btnAddTrack').on('click', function () {
            openModal(null);
        });

        $('#btnSaveTrack').on('click', function () {
            saveTrack();
        });

        $('#tracksTable').on('click', '.btn-edit', function (e) {
            if (e && e.preventDefault) e.preventDefault();
            var id = parseInt($(this).attr('data-id'), 10);
            var track = null;
            for (var i = 0; i < tracks.length; i++) {
                if (tracks[i].Id === id) { track = tracks[i]; break; }
            }
            openModal(track);
        });

        $('#tracksTable').on('click', '.btn-delete', function () {
            var id = parseInt($(this).attr('data-id'), 10);
            deleteTrack(id);
        });
    });
</script>
}
