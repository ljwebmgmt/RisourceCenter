@{
    ViewBag.Title = "Training Admin - Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@media (max-width: 767px) {
        .admin-header-actions .btn {
            display: block;
            width: 100%;
            margin-bottom: 8px;
        }

        .admin-header-actions .btn {
            margin-left: 0 !important;
        }

        .admin-header-actions .btn:last-child {
            margin-bottom: 0;
        }

        #LoadBtn {
            width: 100%;
        }
    }
</style>

<div class="main_content" style="padding-top:20px; padding-bottom:20px;">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xs-12">
                <div class="clearfix">
                    <h2 class="pull-left" style="margin-top:0;">Training Report</h2>
                    <div class="pull-right admin-header-actions" style="margin-top:3px;">
                        <a href="/Training/AdminList" class="btn btn-default btn-sm">Back to Listing</a>
                    </div>
                </div>

                <div class="panel panel-default" style="margin-top:15px;">
                    <div class="panel-heading"><strong>Filters</strong></div>
                    <div class="panel-body">
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Class</label>
                                    <select id="TrainingClassSelect" class="form-control"></select>
                                </div>
                                <div class="form-group">
                                    <label>Training</label>
                                    <select id="TrainingSelect" class="form-control"></select>
                                    <div class="help-block" style="margin-bottom:0;">Leave blank to load all trainings in the selected class.</div>
                                </div>
                                <div class="form-group">
                                    <label>Completion</label>
                                    <select id="CompletionSelect" class="form-control">
                                        <option value="all">All</option>
                                        <option value="started">Started</option>
                                        <option value="completed">Completed</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Passed</label>
                                    <select id="PassedSelect" class="form-control">
                                        <option value="all">All</option>
                                        <option value="yes">Yes</option>
                                        <option value="no">No</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="row">
                                    <div class="col-sm-6">
                                        <div class="form-group">
                                            <label>Start From</label>
                                            <input type="date" id="StartFrom" class="form-control" />
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="form-group">
                                            <label>Start To</label>
                                            <input type="date" id="StartTo" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-6">
                                        <div class="form-group">
                                            <label>End From</label>
                                            <input type="date" id="EndFrom" class="form-control" />
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="form-group">
                                            <label>End To</label>
                                            <input type="date" id="EndTo" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group text-right" style="margin-top:25px;">
                                    <button class="btn btn-primary" id="LoadBtn" type="button">Load Report</button>
                                </div>
                            </div>
                        </div>
                        <div id="reportMessage" class="alert alert-info" style="display:none; margin-top:10px;"></div>
                    </div>
                </div>

                <div class="panel panel-default">
                    <div class="panel-heading"><strong>Results</strong></div>
                    <div class="panel-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered" id="reportTable" style="margin-bottom:0;">
                                <thead>
                                    <tr>
                                        <th style="width:90px;">Training ID</th>
                                        <th>Training</th>
                                        <th style="width:120px;">Class</th>
                                        <th style="width:90px;">Progress ID</th>
                                        <th style="width:90px;">User ID</th>
                                        <th>User</th>
                                        <th>Email</th>
                                        <th style="width:170px;">Started</th>
                                        <th style="width:170px;">Ended</th>
                                        <th style="width:120px;">Time (sec)</th>
                                        <th style="width:120px;">Latest Score</th>
                                        <th style="width:110px;">Passed</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var allTrainings = [];
        var trainingById = {};
        var allRows = [];

        function htmlEncode(value) {
            return $('<div/>').text(value).html();
        }

        function toTitleCase(text) {
            text = (text || '').toString().trim();
            if (!text) return '';
            return text.replace(/\w\S*/g, function (w) {
                return w.charAt(0).toUpperCase() + w.substr(1).toLowerCase();
            });
        }

        function parseLocalDateTime(value) {
            if (!value) return null;
            var s = (value || '').toString().trim();
            if (!s) return null;
            s = s.replace(' ', 'T');
            var d = new Date(s);
            if (isNaN(d.getTime())) return null;
            return d;
        }

        function parseDateOnly(value) {
            var s = (value || '').toString().trim();
            if (!s) return null;
            var d = new Date(s + 'T00:00:00');
            if (isNaN(d.getTime())) return null;
            return d;
        }

        function dateOnlyKey(d) {
            if (!d) return '';
            function pad(n) { return (n < 10 ? '0' : '') + n; }
            return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
        }

        function loadTrainings() {
            $.getJSON('/Training/GetAllTrainingsAdmin', { page: 1, pageSize: 200 }, function (trainings) {
                trainings = trainings || [];
                if (trainings.items) {
                    trainings = trainings.items;
                }
                allTrainings = trainings || [];
                trainingById = {};
                var classes = [];

                for (var i = 0; i < allTrainings.length; i++) {
                    trainingById[allTrainings[i].Id] = allTrainings[i];
                    var cls = (allTrainings[i].TrainingClass || '').toString().trim();
                    if (cls) classes.push(cls);
                }

                classes.sort(function (a, b) { return a.localeCompare(b); });
                var classMap = {};
                var classOptions = '<option value="">-- All Classes --</option>';
                for (var c = 0; c < classes.length; c++) {
                    var key = classes[c].toLowerCase();
                    if (classMap[key]) continue;
                    classMap[key] = true;
                    classOptions += '<option value="' + htmlEncode(classes[c]) + '">' + htmlEncode(toTitleCase(classes[c])) + '</option>';
                }
                $('#TrainingClassSelect').html(classOptions);

                rebuildTrainingOptions();
            });
        }

        function rebuildTrainingOptions() {
            var selectedClass = ($('#TrainingClassSelect').val() || '').toString().trim().toLowerCase();
            var currentSelected = $('#TrainingSelect').val() || [];
            var html = '<option value="">-- All Trainings --</option>';
            for (var i = 0; i < allTrainings.length; i++) {
                var t = allTrainings[i];
                var cls = (t.TrainingClass || '').toString().trim().toLowerCase();
                if (selectedClass && cls !== selectedClass) continue;
                var label = (t.Title || '');
                if (t.TrainingClass) {
                    label += ' (' + toTitleCase(t.TrainingClass) + ')';
                }
                html += '<option value="' + t.Id + '">' + htmlEncode(label) + '</option>';
            }
            $('#TrainingSelect').html(html);
            $('#TrainingSelect').val(currentSelected);
        }

        function renderRows(rows) {
            var html = '';
            for (var i = 0; i < rows.length; i++) {
                var r = rows[i];
                var latest = r.LatestAttempt;
                var latestScore = latest ? (latest.ScorePercentage + '%') : '';
                var latestPassed = latest ? (latest.IsPassed ? 'Yes' : 'No') : '';

                html += '<tr>';
                html += '<td>' + (r.TrainingContentId || '') + '</td>';
                html += '<td>' + htmlEncode(r.TrainingTitle || '') + '</td>';
                html += '<td>' + htmlEncode(toTitleCase(r.TrainingClass || '')) + '</td>';
                html += '<td>' + r.Id + '</td>';
                html += '<td>' + r.UserId + '</td>';
                html += '<td>' + htmlEncode(r.UserName || '') + '</td>';
                html += '<td>' + htmlEncode(r.UserEmail || '') + '</td>';
                html += '<td>' + htmlEncode(r.StartTime || '') + '</td>';
                html += '<td>' + htmlEncode(r.EndTime || '') + '</td>';
                html += '<td>' + (r.ElapsedSeconds || 0) + '</td>';
                html += '<td>' + htmlEncode(latestScore) + '</td>';
                html += '<td>' + htmlEncode(latestPassed) + '</td>';
                html += '</tr>';
            }
            $('#reportTable tbody').html(html);
        }

        function applyFilters(rows) {
            var completion = ($('#CompletionSelect').val() || 'all').toString().toLowerCase();
            var passed = ($('#PassedSelect').val() || 'all').toString().toLowerCase();

            var startFrom = parseDateOnly($('#StartFrom').val());
            var startTo = parseDateOnly($('#StartTo').val());
            var endFrom = parseDateOnly($('#EndFrom').val());
            var endTo = parseDateOnly($('#EndTo').val());

            var startFromKey = startFrom ? dateOnlyKey(startFrom) : '';
            var startToKey = startTo ? dateOnlyKey(startTo) : '';
            var endFromKey = endFrom ? dateOnlyKey(endFrom) : '';
            var endToKey = endTo ? dateOnlyKey(endTo) : '';

            var filtered = [];
            for (var i = 0; i < rows.length; i++) {
                var r = rows[i];

                if (completion === 'completed' && !r.EndTime) continue;
                if (completion === 'started' && !r.StartTime) continue;

                if (passed !== 'all') {
                    var latest = r.LatestAttempt;
                    var latestIsPassed = latest ? latest.IsPassed : null;
                    if (passed === 'yes' && latestIsPassed !== true) continue;
                    if (passed === 'no' && latestIsPassed !== false) continue;
                }

                var startD = parseLocalDateTime(r.StartTime);
                if (startD) {
                    var startKey = dateOnlyKey(startD);
                    if (startFromKey && startKey < startFromKey) continue;
                    if (startToKey && startKey > startToKey) continue;
                } else {
                    if (startFromKey || startToKey) continue;
                }

                if (endFromKey || endToKey) {
                    var endD = parseLocalDateTime(r.EndTime);
                    if (endD) {
                        var endKey = dateOnlyKey(endD);
                        if (endFromKey && endKey < endFromKey) continue;
                        if (endToKey && endKey > endToKey) continue;
                    } else {
                        continue;
                    }
                }

                filtered.push(r);
            }

            return filtered;
        }

        function loadReport() {
            var selectedClass = ($('#TrainingClassSelect').val() || '').toString().trim().toLowerCase();
            var trainingId = parseInt($('#TrainingSelect').val(), 10);
            var ids = [];

            if (trainingId) {
                ids = [trainingId];
            } else {
                for (var i = 0; i < allTrainings.length; i++) {
                    var t = allTrainings[i];
                    var cls = (t.TrainingClass || '').toString().trim().toLowerCase();
                    if (selectedClass && cls !== selectedClass) continue;
                    ids.push(t.Id);
                }
            }

            if (!ids.length) {
                $('#reportMessage').text('No trainings found for the selected class.').show();
                return;
            }

            $('#reportMessage').hide();

            $.getJSON('/Training/GetTrainingStatsAdminMulti', { trainingContentIds: ids }, function (rows) {
                rows = rows || [];
                allRows = rows;
                var filtered = applyFilters(allRows);
                renderRows(filtered);
                if (!filtered.length) {
                    $('#reportMessage').text('No progress records found for the selected trainings.').show();
                }
            }).fail(function (xhr) {
                $('#reportMessage').text(xhr.responseText || 'Unable to load report.').show();
            });
        }

        function rerenderFiltered() {
            if (!allRows || !allRows.length) {
                $('#reportTable tbody').html('');
                return;
            }
            var filtered = applyFilters(allRows);
            renderRows(filtered);
            if (!filtered.length) {
                $('#reportMessage').text('No progress records match the selected filters.').show();
            } else {
                $('#reportMessage').hide();
            }
        }

        $('#LoadBtn').on('click', loadReport);
        $('#TrainingClassSelect').on('change', function () {
            rebuildTrainingOptions();
        });
        $('#CompletionSelect, #PassedSelect, #StartFrom, #StartTo, #EndFrom, #EndTo').on('change', function () {
            rerenderFiltered();
        });
        loadTrainings();
    })();
</script>
