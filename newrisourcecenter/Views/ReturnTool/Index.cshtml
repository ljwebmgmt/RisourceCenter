@model IEnumerable<newrisourcecenter.Models.ReturnTools>

@{
    ViewBag.Title = Request.QueryString["n1_name"];
    string userProducts = Convert.ToString(Session["userProducts"]);
    string pages = Convert.ToString(Session["userPages"]);
    string[] userpages = { };
    if (pages != null)
    {
        userpages = pages.Split(',');
    }
}
<div id="theusers" style="display:none;">
    <option>Select a requester</option>
    @Html.Raw(ViewBag.list_users)

</div>
<style type="text/css">
    .btn.btn-xs {
        padding: 1px 5px !important;
        height: auto !important;
    }
</style>
<script>
    let gridApi;

    const columnDefs = [
        { headerName: "Form ID", field: "form_id", sortable: true, filter: true, width: 120 },
        {
            headerName: "Date Submitted",
            field: "submission_date",
            sortable: true,
            filter: 'agDateColumnFilter',
            valueFormatter: params => formatDate(params.value)
        },
        {
            headerName: "Date Completed",
            field: "completion_date",
            sortable: true,
            filter: 'agDateColumnFilter',
            valueFormatter: params => formatDate(params.value)
        },
        { headerName: "Status", field: "status", sortable: true, filter: true },
        {
            headerName: "Actions",
            sortable: false,
            filter: false,
            cellRenderer: params => {
                const id = params.data.form_id;
                const n1 = "@Request.QueryString["n1_name"]";
                return `
                    <a href="/ReturnTool/Edit?id=${id}&n1_name=${n1}" class="btn btn-xs btn-info">Edit</a>
                    <a href="/ReturnTool/Delete?id=${id}&n1_name=${n1}" onclick="deletef(this.href);return false" class="btn btn-xs btn-danger">Delete</button>
                `;
            }
        }
    ];

    const gridOptions = {
        columnDefs: columnDefs,
        rowData: @Html.Raw(Json.Encode(Model)), // Direct serialization of your list
        pagination: true,
        paginationPageSize: 15,
        defaultColDef: {
            flex: 1,
            resizable: true
        }
    };

    function formatDate(dateStr) {
        if (!dateStr) return "";
        const ms = parseInt(dateStr.replace(/\/Date\((\d+)\)\//, '$1'));
        return new Date(ms).toLocaleDateString();
    }

    document.addEventListener('DOMContentLoaded', () => {
        const gridDiv = document.querySelector('#returnGrid');
        gridApi = agGrid.createGrid(gridDiv, gridOptions);
    });
</script>
<div class="main_content">
    <table style="width:100%;text-align:center !important;margin-bottom:10px;" align="center">
        <tr>
            <td>
                @Html.ActionLink("Submit a Return Request >>", "Create", new { n1_name = @Request.QueryString["n1_name"], msg = "Submit a Return Request" }, htmlAttributes: new { @style = "float:left;", @class = "btn btn-primary" })
            </td>
            <td>
                @if (userpages.Contains("74") || userpages.Contains("76"))
                {
                    @Html.ActionLink("Admin Panel >>", "AdminPanel", new { n1_name = @Request.QueryString["n1_name"], msg = "Admin Panel" }, htmlAttributes: new { @style = "float:right;", @class = "btn btn-primary" })
                }
            </td>
        </tr>
    </table>
    <div class="table-wrapper" style="clear:both;">
        <div id="returnGrid" class="ag-theme-quartz" style="height: 600px; width: 100%;"></div>
    </div>
</div>
